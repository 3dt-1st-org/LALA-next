# LALA-next local development configuration.
# Copy to .env and fill values locally. Do not commit real secret values.

IOS_API_KEY=
API_BEARER_TOKEN=
LALA_PUBLIC_CONTEST_ACCESS=false
LALA_SMOKE_BEARER_TOKEN=
LALA_SMOKE_API_KEY=
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_JWKS_URL=
OAUTH_CLIENT_ID=
OAUTH_REQUIRED_SCOPES=
KAKAO_REST_API_KEY=
KAKAO_JAVASCRIPT_KEY=
KAKAO_REDIRECT_URI=https://api.lala-next.cloud/auth/kakao/callback
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
KOPIS_API_KEY=
PUBLIC_DATA_SERVICE_KEY=
GYEONGGI_DATA_DREAM_API_KEY=
DB_DSN=
LALA_POSTGRES_USER=lala
LALA_POSTGRES_PASSWORD=
LALA_POSTGRES_DB=lala
LALA_POSTGRES_PORT=55432
KEY_VAULT_URL=
LALA_ALLOWED_KEY_VAULT_HOSTS=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
# Recommended: deployment backed by gpt-5.4-mini for docent generation, QA,
# and judge-facing final wording.
AZURE_OPENAI_DOCENT_DEPLOYMENT=
# Recommended: deployment backed by gpt-5.4-nano for bulk review attribute,
# ad-filter, and mention-normalization batches.
AZURE_OPENAI_REVIEW_BATCH_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDING_API_VERSION=
AZURE_OPENAI_KEY=
# OpenAI (standard api.openai.com) — used for RAG embeddings when AZURE_OPENAI_* is absent
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LALA_ENABLE_LIVE_AI=false
AZURE_SPEECH_REGION=koreacentral
AZURE_SPEECH_ENDPOINT=
AZURE_SPEECH_KEY=
LALA_ENABLE_LIVE_SPEECH=false
CORS_ALLOW_ORIGINS=
LOG_LEVEL=INFO
LALA_ACCESS_LOG_PATH=
